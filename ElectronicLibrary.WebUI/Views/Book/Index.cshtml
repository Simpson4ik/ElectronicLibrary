@model ElectronicLibrary.Core.Models.PaginatedList<ElectronicLibrary.Core.Entities.Book>

@{
    ViewData["Title"] = "Каталог книг";
}

<h2>Каталог бібліотеки</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="card mb-4 mt-3">
    <div class="card-body bg-light">
        <form asp-action="Index" method="get" class="row g-3 align-items-center">
            <input type="hidden" name="sortOrder" value="@ViewBag.CurrentSort" />

            <div class="col-md-5">
                <input type="text" name="searchTerm" class="form-control" placeholder="Пошук за назвою чи автором..." value="@ViewBag.SearchTerm" />
            </div>
            
            <div class="col-md-4">
                <div class="form-check">
                    <input class="form-check-input" type="checkbox" name="onlyAvailable" id="onlyAvailable" value="true" @(ViewBag.OnlyAvailable == true ? "checked" : "")>
                    <label class="form-check-label" for="onlyAvailable">
                        Показувати лише доступні
                    </label>
                </div>
            </div>
            
            <div class="col-md-3 d-flex gap-2">
                <button type="submit" class="btn btn-primary w-100">🔍 Знайти</button>
                <a asp-action="Index" class="btn btn-outline-secondary">Скинути</a>
            </div>
        </form>
    </div>
</div>

<div class="mb-3 d-flex justify-content-between align-items-center">
    <div>
        <a asp-action="Create" class="btn btn-success">+ Додати нову книгу</a>
    </div>
    <div>
        <span>Сортувати за: </span>
        <a asp-action="Index"
           asp-route-sortOrder="title"
           asp-route-searchTerm="@ViewBag.SearchTerm"
           asp-route-onlyAvailable="@ViewBag.OnlyAvailable"
           class="btn btn-sm @(ViewBag.CurrentSort == "title" ? "btn-primary" : "btn-outline-primary")">Алфавітом</a>
           
        <a asp-action="Index"
           asp-route-sortOrder="year"
           asp-route-searchTerm="@ViewBag.SearchTerm"
           asp-route-onlyAvailable="@ViewBag.OnlyAvailable"
           class="btn btn-sm @(ViewBag.CurrentSort == "year" ? "btn-primary" : "btn-outline-primary")">Роком видання</a>
    </div>
</div>

<table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Назва</th>
            <th>Автор</th>
            <th>Рік</th>
            <th>ISBN</th>
            <th>Статус</th>
            <th>Дії</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var book in Model.Items)
        {
            <tr>
                <td>@book.Title</td>
                <td>@book.Author</td>
                <td>@book.PublicationYear</td>
                <td>@book.Isbn</td>
                <td>
                    @if (book.IsAvailable)
                    {
                        <span class="badge bg-success">Доступна</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Видана</span>
                    }
                </td>
                <td>
                    <div class="d-flex gap-2">
                        @if (book.IsAvailable)
                        {
                            <form asp-action="Borrow" asp-route-id="@book.Id" method="post">
                                <button type="submit" class="btn btn-sm btn-success">Позичити</button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="Return" asp-route-id="@book.Id" method="post">
                                <button type="submit" class="btn btn-sm btn-warning">Повернути</button>
                            </form>
                        }

                        <a asp-action="Edit" asp-route-id="@book.Id" class="btn btn-sm btn-outline-primary" title="Редагувати">⚙️</a>
                        
                        <form asp-action="Delete" asp-route-id="@book.Id" method="post" onsubmit="return confirm('Ви впевнені, що хочете видалити цю книгу?')">
                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Видалити">🗑️</button>
                        </form>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>

@if (Model.TotalPages > 1)
{
    <nav aria-label="Навігація по сторінках" class="mt-4">
        <ul class="pagination justify-content-center">
            <li class="page-item @(!Model.HasPreviousPage ? "disabled" : "")">
                <a class="page-link" asp-action="Index"
                   asp-route-pageNumber="@(Model.PageIndex - 1)"
                   asp-route-sortOrder="@ViewBag.CurrentSort"
                   asp-route-searchTerm="@ViewBag.SearchTerm"
                   asp-route-onlyAvailable="@ViewBag.OnlyAvailable">Попередня</a>
            </li>
            
            @for (int i = 1; i <= Model.TotalPages; i++)
            {
                <li class="page-item @(i == Model.PageIndex ? "active" : "")">
                    <a class="page-link" asp-action="Index"
                       asp-route-pageNumber="@i"
                       asp-route-sortOrder="@ViewBag.CurrentSort"
                       asp-route-searchTerm="@ViewBag.SearchTerm"
                       asp-route-onlyAvailable="@ViewBag.OnlyAvailable">@i</a>
                </li>
            }

            <li class="page-item @(!Model.HasNextPage ? "disabled" : "")">
                <a class="page-link" asp-action="Index"
                   asp-route-pageNumber="@(Model.PageIndex + 1)"
                   asp-route-sortOrder="@ViewBag.CurrentSort"
                   asp-route-searchTerm="@ViewBag.SearchTerm"
                   asp-route-onlyAvailable="@ViewBag.OnlyAvailable">Наступна</a>
            </li>
        </ul>
    </nav>
}