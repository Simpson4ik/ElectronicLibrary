@model IEnumerable<ElectronicLibrary.Core.Entities.Book>

@{
    ViewData["Title"] = "Каталог книг";
}

<h2>Каталог бібліотеки</h2>

@if (TempData["SuccessMessage"] != null)
{
    <div class="alert alert-success alert-dismissible fade show" role="alert">
        @TempData["SuccessMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

@if (TempData["ErrorMessage"] != null)
{
    <div class="alert alert-danger alert-dismissible fade show" role="alert">
        @TempData["ErrorMessage"]
        <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
    </div>
}

<div class="mb-3 d-flex justify-content-between align-items-center">
    <div>
        <a asp-action="Create" class="btn btn-success">+ Додати нову книгу</a>
    </div>
    <div>
        <span>Сортувати за: </span>
        <a asp-action="Index" asp-route-sortOrder="title" class="btn btn-sm @(ViewBag.CurrentSort == "title" ? "btn-primary" : "btn-outline-primary")">Алфавітом</a>
        <a asp-action="Index" asp-route-sortOrder="year" class="btn btn-sm @(ViewBag.CurrentSort == "year" ? "btn-primary" : "btn-outline-primary")">Роком видання</a>
    </div>
</div>

<table class="table table-striped table-hover align-middle">
    <thead class="table-dark">
        <tr>
            <th>Назва</th>
            <th>Автор</th>
            <th>Рік</th>
            <th>ISBN</th>
            <th>Статус</th>
            <th>Дії</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var book in Model)
        {
            <tr>
                <td>@book.Title</td>
                <td>@book.Author</td>
                <td>@book.PublicationYear</td>
                <td>@book.Isbn</td>
                <td>
                    @if (book.IsAvailable)
                    {
                        <span class="badge bg-success">Доступна</span>
                    }
                    else
                    {
                        <span class="badge bg-danger">Видана</span>
                    }
                </td>
                <td>
                    <div class="d-flex gap-2">
                        @if (book.IsAvailable)
                        {
                            <form asp-action="Borrow" asp-route-id="@book.Id" method="post">
                                <button type="submit" class="btn btn-sm btn-success">Позичити</button>
                            </form>
                        }
                        else
                        {
                            <form asp-action="Return" asp-route-id="@book.Id" method="post">
                                <button type="submit" class="btn btn-sm btn-warning">Повернути</button>
                            </form>
                        }

                        <a asp-action="Edit" asp-route-id="@book.Id" class="btn btn-sm btn-outline-primary" title="Редагувати">⚙️</a>
                        
                        <form asp-action="Delete" asp-route-id="@book.Id" method="post" onsubmit="return confirm('Ви впевнені, що хочете видалити цю книгу?')">
                            <button type="submit" class="btn btn-sm btn-outline-danger" title="Видалити">🗑️</button>
                        </form>
                    </div>
                </td>
            </tr>
        }
    </tbody>
</table>